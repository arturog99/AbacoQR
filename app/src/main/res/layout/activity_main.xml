<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF4F4"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- BARRA SUPERIOR (TOOLBAR) -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#960018">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar_main"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="AbacoQR - Gestión"
                app:titleTextColor="@android:color/white" />
        </com.google.android.material.appbar.AppBarLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/main_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gestión de Inventario"
                    android:textColor="#960018"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvSubtitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Módulo de Gestión y QR"
                    android:textColor="#757575"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitulo" />

                <Button
                    android:id="@+id/btnCargarCsv"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:text="1. Cargar datos desde CSV"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:backgroundTint="#960018"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/tvSubtitulo" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/panelEstadisticas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:layout_constraintTop_toBottomOf="@id/btnCargarCsv">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="Resumen de la importación"
                            android:textColor="#960018"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total leídos: 0"
                            android:textColor="#424242"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvActivos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="✅ Filtrados para QR: 0"
                            android:textColor="#2E7D32"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvInoperativos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="❌ Descartados: 0"
                            android:textColor="#C62828"
                            android:textSize="16sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Button
                    android:id="@+id/btnGenerarPdf"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="24dp"
                    android:enabled="false"
                    android:text="2. Generar etiquetas QR"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:backgroundTint="#960018"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/panelEstadisticas" />

                <Button
                    android:id="@+id/btnEscanearQr"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="3. Escanear QR físico"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:backgroundTint="#424242"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/btnGenerarPdf" />

                <Button
                    android:id="@+id/btnIrABusqueda"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="4. Buscar en el Inventario"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:enabled="false"
                    app:backgroundTint="#960018"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/btnEscanearQr" />

                <Button
                    android:id="@+id/btnGuardarFinal"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="5. Guardar Cambios en CSV"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:enabled="false"
                    app:backgroundTint="#2E7D32"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/btnIrABusqueda" />

                <!-- BOTÓN EXPORTAR (NUEVO) -->
                <Button
                    android:id="@+id/btnExportarCompartir"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="6. Exportar y Compartir CSV"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:enabled="false"
                    app:backgroundTint="#1976D2"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/btnGuardarFinal" />

                <Button
                    android:id="@+id/btnVerHistorial"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Ver Historial de Cambios"
                    android:textColor="#424242"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnExportarCompartir" />

                <Button
                    android:id="@+id/btnManualUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="Manual de Usuario 📖"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:backgroundTint="#1976D2"
                    app:cornerRadius="12dp"
                    app:layout_constraintTop_toBottomOf="@id/btnVerHistorial" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_dispositivo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Añadir nuevo equipo"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#960018"
        app:tint="@android:color/white"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>