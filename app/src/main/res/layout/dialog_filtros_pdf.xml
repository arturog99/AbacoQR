<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FAF4F4"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FILTRAR ETIQUETAS QR"
            android:textColor="#960018"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configura los criterios para generar el PDF. Deja vacío lo que no quieras filtrar."
            android:textColor="#757575"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- Filtro: Estado de Verificación (NUEVO) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Mostrar solo verificados?"
                    android:textSize="12sp"
                    android:textColor="#960018"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <Spinner
                    android:id="@+id/spinner_filtro_verificacion"
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Filtro: Estado (Activo, Inoperativo...) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#DDDDDD">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estado del equipo:"
                    android:textSize="12sp"
                    android:textColor="#960018"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <Spinner
                    android:id="@+id/spinner_filtro_estado"
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Filtro: Centro -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Centro / Propietario"
            app:boxStrokeColor="#960018"
            app:hintTextColor="#960018"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_filtro_centro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Filtro: Artículo -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Artículo"
            app:boxStrokeColor="#960018"
            app:hintTextColor="#960018"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_filtro_articulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Planta"
                app:boxStrokeColor="#960018"
                app:hintTextColor="#960018"
                android:layout_marginEnd="6dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_filtro_planta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Aula"
                app:boxStrokeColor="#960018"
                app:hintTextColor="#960018"
                android:layout_marginStart="6dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_filtro_aula"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>