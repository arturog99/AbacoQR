<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAF4F4"
    android:fitsSystemWindows="true"
    tools:context=".ui.search.SearchResultsActivity">

    <!-- BARRA SUPERIOR FIJA -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#960018">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_search_results"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Gestión de Búsqueda"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="?attr/homeAsUpIndicator" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- PANEL DE BÚSQUEDA AUTOMÁTICA -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buscar por:"
                android:textSize="11sp"
                android:textColor="#960018"
                android:textStyle="bold" />
            
            <Spinner
                android:id="@+id/spinner_search_field_activity"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado de verificación:"
                android:textSize="11sp"
                android:textColor="#960018"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_search_verif_activity"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Escribe tu búsqueda..."
                app:boxStrokeColor="#960018"
                app:hintTextColor="#960018">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search_query_activity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_search_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="8dp"
        android:textColor="#757575"
        android:textSize="14sp"
        android:textStyle="italic"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_search_results"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:scrollbarSize="8dp"
            android:scrollbarStyle="outsideOverlay"
            android:fadeScrollbars="false"
            android:fastScrollEnabled="true"
            app:fastScrollVerticalThumbDrawable="@drawable/scrollbar_thumb"
            app:fastScrollVerticalTrackDrawable="@drawable/scrollbar_track"
            app:fastScrollHorizontalThumbDrawable="@drawable/scrollbar_thumb"
            app:fastScrollHorizontalTrackDrawable="@drawable/scrollbar_track"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

        <ProgressBar
            android:id="@+id/search_loading_indicator"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="#960018" />
    </FrameLayout>

</LinearLayout>