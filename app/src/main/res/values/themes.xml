<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AbacoQR" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colores para tema claro -->
        <item name="colorPrimary">#960018</item>
        <item name="colorPrimaryVariant">#7a0013</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorAccent">#960018</item>
        
        <!-- Colores de fondo y superficie -->
        <item name="android:colorBackground">#FAF4F4</item>
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">#212121</item>
        
        <!-- Colores para texto -->
        <item name="android:textColorPrimary">#212121</item>
        <item name="android:textColorSecondary">#757575</item>
    </style>

    <style name="Theme.AbacoQR" parent="Base.Theme.AbacoQR" />

    <!-- TEMA PARA LA PANTALLA DE INICIO (SPLASH) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Fondo de la pantalla de carga -->
        <item name="windowSplashScreenBackground">#960018</item>
        <!-- Tu icono personalizado (usa el mismo que generaste en el paso 1) -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Tema al que cambiará cuando la app termine de cargar -->
        <item name="postSplashScreenTheme">@style/Theme.AbacoQR</item>
    </style>

    <!-- Estilo personalizado para TextInputLayout en tema claro -->
    <style name="Theme.AbacoQR.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@android:color/white</item>
        <item name="boxStrokeColor">#960018</item>
        <item name="hintTextColor">#757575</item>
        <item name="android:textColorHint">#757575</item>
        <item name="passwordToggleTint">#757575</item>
    </style>

    <!-- Estilo para Spinner en tema claro -->
    <style name="Theme.AbacoQR.Spinner" parent="Widget.AppCompat.Spinner.DropDown">
        <item name="android:textColor">#212121</item>
        <item name="android:backgroundTint">@android:color/white</item>
        <item name="android:popupBackground">@android:color/white</item>
    </style>

    <!-- Estilo para dropdown items en tema claro -->
    <style name="Theme.AbacoQR.SpinnerDropdownItem" parent="Widget.AppCompat.DropDownItem.Spinner">
        <item name="android:textColor">#212121</item>
        <item name="android:background">@android:color/white</item>
        <item name="android:padding">12dp</item>
    </style>
</resources>